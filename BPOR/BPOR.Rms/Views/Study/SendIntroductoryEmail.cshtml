@model BPOR.Rms.Models.Study.StudyDetailsViewModel

@{
    ViewData["Title"] = "Send Introductory Email";
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData.AddBreadcrumbs(new Dictionary<string, string>
        {
            ["All studies"] = "/Study/Index",
            ["Study"] = "/Study/Index",
        }
    );
}

< style="display:flex;gap: 10px; flex-direction: column; width: 100%">

<h1 class="govuk-heading-l">
    @Html.DisplayFor(model => model.Study.StudyName)
</h1>

<h2 class="govuk-heading-m">Introduction Email</h2>


<div class="govuk-inset-text">
    @if (Model.Study.IsEligibleForPrescreener)
    {
        <span>This study is eligible for a pre-screener</span>
    }
    else
    {
        <span>This study is <strong>not</strong> eligible for a pre-screener</span>
    }
</div>

<form>
    @if (Model.Study.IsEligibleForPrescreener)
    {
        <div class="govuk-form-group">
            <fieldset class="govuk-fieldset">
                <div class="govuk-radios" data-module="govuk-radios">
                    <div class="govuk-radios__item">
                        <input class="govuk-radios__input" id="IncludePreScreener" name="IncludePreScreener"
                               type="radio" value="false">
                        <label class="govuk-label govuk-radios__label" for="whereDoYouLive">
                            RMS Only
                        </label>
                    </div>
                    <div class="govuk-radios__item">
                        <input class="govuk-radios__input" id="IncludePreScreener-2" name="IncludePreScreener"
                               type="radio" value="true">
                        <label class="govuk-label govuk-radios__label" for="whereDoYouLive-2">
                            RMS and Pre-creener
                        </label>
                    </div>
                </div>
            </fieldset>
        </div>
    }

    <button type="submit" id="applyForStudyBtn" class="govuk-button govuk-button">
        Send Introduction Email
    </button>
</form>
