@{
    Layout = "_Layout";
}

@model BPOR.Rms.Models.Study.VolunteerInformation.IVsiEditModel

@{
    ViewData["Title"] = Model.StepName;
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData.AddBreadcrumbs(new Dictionary<string, string>
    {
        ["All studies"] = "/Study/Index",
        ["Study page"] = $"/Study/Details/{Model.Id}",
        ["Edit study"] = "/Study/Edit",
    });
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <h1 class="govuk-heading-xl">Edit Volunteer Study Information details</h1>
        
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="Step" value="@Model.Step" />
            
            @RenderBody()
            
            <div class="govuk-button-group">
                <button type="submit" class="govuk-button" data_module="govuk-button">Update</button>
                @Html.ActionLink("Cancel", "Details", "Study", new { id = Model.Id }, new { data_module = "govuk-button" })
            </div>
        </form>
    </div>
</div>
