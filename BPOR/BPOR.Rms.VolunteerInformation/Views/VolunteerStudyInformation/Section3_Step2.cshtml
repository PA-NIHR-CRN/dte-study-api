
@model VsiEditModel

@{
    VsiEditContext context = ViewBag.Context;
    context.SectionName = Resources.Section3Name;
    context.SkipUrl = Url.Action("Section3_Step3", new { context.StudyId });
    ViewData.SetBackLinkOverride(Url.Action("Section3_Step1", new { id = context.StudyId }));
    Layout = "_VsiEditLayoutForm";
}

<form-group for="ExternalWebsiteUrl">
    <input class="govuk-input" asp-for="ExternalWebsiteUrl" type="text">
</form-group>