@model CreateGroupModel

@{
    VsiEditContext context = ViewBag.Context;
    context.SectionName = BPOR.Rms.VolunteerInformation.Resources.Section1Name;
    Layout = "_VsiEditLayout";
}

<form method="post">
    <form-group for="Name" label="Create volunteer groups">
        <p>If your study requires multiple groups, you can add more after providing information for each group.</p>
        <p>Enter a name for this group</p>
        <input class="govuk-input" asp-for="Name" type="text">
    </form-group>
    <button class="govuk-button" type="submit">Submit</button>
</form>