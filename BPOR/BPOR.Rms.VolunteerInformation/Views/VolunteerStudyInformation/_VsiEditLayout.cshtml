@{
    Layout = "_Layout";
    VsiEditContext context = ViewBag.Context;
    ViewData["Title"] = context.SectionName;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <h1 class="govuk-heading-xl">@context.SectionName</h1>
        
            <back-link href="@context.BackUrl"/>
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            @RenderBody()

            <div class="govuk-button-group">
                <button type="submit" class="govuk-button" data_module="govuk-button">Update</button>
            </div>
    </div>
</div>
