@{
    Layout = "_Layout";
}

@using NIHR.GovUk.AspNetCore.Mvc
@model BPOR.Rms.VolunteerInformation.Models.VsiEditModel

@{
    ViewData["Title"] = ViewBag.SectionName;
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData.AddBreadcrumbs(new Dictionary<string, string>
    {
        ["All studies"] = "/Study/Index",
        ["Study page"] = $"/Study/Details/{Model.StudyId}",
        ["Edit study"] = "/Study/Edit",
    });
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <h1 class="govuk-heading-xl">@ViewBag.SectionName</h1>
        
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            @RenderBody()
            
            <div class="govuk-button-group">
                <button type="submit" class="govuk-button" data_module="govuk-button">Update</button>
                @Html.ActionLink("Cancel", "Details", "Study", new { id = Model.StudyId }, new { data_module = "govuk-button" })
            </div>
        </form>
    </div>
</div>
