@using BPOR.Domain.Enums
@model VsiEditModel

@{
    VsiEditContext context = ViewBag.Context;
    ViewData.SetBackLinkOverride(Url.Action("Section1_Step1", new{ context.Vsi.StudyId }));
    context.SectionName = Resources.Section1Name;
    Layout = "_VsiEditLayoutForm";
}

<form-group for="StudyType" label-class="govuk-heading-xl">
    <radio-set for="StudyType">
        <radio value="@VsiStudyTypeId.InPerson">In Person / On Site</radio>
        <radio value="@VsiStudyTypeId.Remote">Remote / Online</radio>
        <radio value="@VsiStudyTypeId.Hybrid">Hybrid</radio>
    </radio-set>
</form-group>