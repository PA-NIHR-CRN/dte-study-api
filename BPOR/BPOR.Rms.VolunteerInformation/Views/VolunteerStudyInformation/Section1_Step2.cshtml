@using BPOR.Rms.Abstractions.Enums
@model VsiEditModel

@{
    VsiEditContext context = ViewBag.Context;
    ViewData.SetBackLinkOverride(Url.FlowNext(context, "Section1_Step1"));
    ViewData.SetSectionName(Resources.Section1Name);
    Layout = "_VsiEditLayoutForm";
}

<form-group for="StudyType" label-class="govuk-heading-l">
    <radio-set for="StudyType">
        <radio value="@VsiStudyType.InPerson">In Person / On Site</radio>
        <radio value="@VsiStudyType.Remote">Remote / Online</radio>
        <radio value="@VsiStudyType.Hybrid">Hybrid</radio>
    </radio-set>
</form-group>