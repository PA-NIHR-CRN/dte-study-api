@using BPOR.Domain.Enums
@using BPOR.Rms.Abstractions.Enums
@model BPOR.Rms.VolunteerInformation.Models.VsiEditModel

@{
    VsiEditContext context = ViewBag.Context;
    context.SectionName = Resources.Section1Name;
    Layout = "_VsiEditLayout";
}

<h1>Check the details you've provided</h1>
@foreach (var group in Model.Groups)
{
    <h2>Create Volunteer Groups</h2>
    <dl class="govuk-summary-list">
        <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">
                Enter a name for this group
            </dt>
            <dd class="govuk-summary-list__value">
                @group.Name
            </dd>
            <dd class="govuk-summary-list__actions">
                <form method="post" asp-action="RemoveGroup" asp-controller="Group" asp-route-studyId="@context.StudyId" asp-route-groupId="@group.Id">
                    <button class="govuk-link" type="submit">Delete</button>
                </form>
            </dd>
        </div>
    </dl>

    <h2>Add inclusion Criteria</h2>
    <dl class="govuk-summary-list">
        <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">
                Inclusion criteria for @group.Name
            </dt>
            <dd class="govuk-summary-list__value">
                <ul>
                    @foreach (var criterion in group.Criteria.Where(i => i.Type == VsiGroupCriteronType.Include))
                    {
                        <li>@criterion.Description</li>
                    }
                </ul>
            </dd>
            <dd class="govuk-summary-list__actions">
                <a asp-action="Criteria" asp-controller="Group" asp-route-studyId="@context.StudyId" asp-route-groupId="@group.Id" asp-route-type="Include">Change</a>
            </dd>
        </div>
    </dl>

    <h2>Add exclusion Criteria</h2>
    <dl class="govuk-summary-list">
        <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">
                Exclusion criteria for @group.Name
            </dt>
            <dd class="govuk-summary-list__value">
                <ul>
                    @foreach (var criterion in group.Criteria.Where(i => i.Type == VsiGroupCriteronType.Exclude))
                    {
                        <li>@criterion.Description</li>
                    }
                </ul>
            </dd>
            <dd class="govuk-summary-list__actions">
                <a asp-action="Criteria" asp-controller="Group" asp-route-studyId="@context.StudyId" asp-route-groupId="@group.Id" asp-route-type="Exclude">Change</a>
            </dd>
        </div>
    </dl>
}

<div class="govuk-!-margin-3">
    <a asp-action="CreateGroup" asp-route-studyid="@context.StudyId" 
       class="govuk-link" >Add another group</a>
</div>
<div>
<a asp-action="Section2_Step1" asp-route-studyid="@context.StudyId" 
   class="govuk-button" data-module="govuk-button">Continue</a>
</div>