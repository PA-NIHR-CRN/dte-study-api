@using NIHR.GovUk.AspNetCore.Mvc
@model VsiEditModel

@{
    VsiEditContext context = ViewBag.Context;
    context.SectionName = Resources.Section3Name;
    ViewData.SetBackLinkOverride(Url.Action("Section2_Step7", new { context.StudyId }));
    context.SkipUrl = Url.Action("Section3_Step2", new { context.StudyId });
    Layout = "_VsiEditLayoutForm";
}

<form-group for="StagedPreScreenerUrl" label-class="govuk-heading-xl">
    <input class="govuk-input" asp-for="StagedPreScreenerUrl" type="text">
</form-group>