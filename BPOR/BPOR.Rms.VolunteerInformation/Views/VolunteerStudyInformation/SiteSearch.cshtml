@model BPOR.Rms.VolunteerInformation.Models.SiteSearchModel

@{
    VsiEditContext context = ViewBag.Context;
    context.SectionName = Resources.Section1Name;
}

<h1>Research Location</h1>

<form>
    <form-group for="SearchTerm" label="Research location" label-class="govuk-heading-xl"
                description="Enter a postcode to select one or multiple research locations">
        <input class="govuk-input" asp-for="SearchTerm" type="text">
    </form-group>
    <button class="govuk-button" type="submit">Search postcode</button>
</form>

@if (Model.SearchResult?.Any() == true)
{
    <form method="post">
        <div class="govuk-form-group">
            <fieldset class="govuk-fieldset">
                <radio-set for="SelectedRtsId">
                    @foreach (var result in Model.SearchResult)
                    {
                        <radio value="@result.Id">@result.ToString()</radio>
                    }
                </radio-set>
            </fieldset>
        </div>
        <button class="govuk-button" type="submit">submit</button>
    </form>
}

<a class="govuk-link" asp-action="ManualSiteEntry" asp-route-studyId="@context.StudyId">Add address manually</a>

