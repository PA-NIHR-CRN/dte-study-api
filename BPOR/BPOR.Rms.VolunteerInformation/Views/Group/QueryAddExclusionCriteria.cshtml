@model BPOR.Rms.VolunteerInformation.Models.VsiGroupModel

@{
    VsiGroupEditContext context = ViewBag.Context;
    ViewData.SetSectionName(Resources.Section1Name);
    Layout = "_VsiEditLayoutForm";
}

<form-group for="Criteria" label="Would you like to add exclusion criteria?" label-class="govuk-heading-l">
    <radio-set name="addExclusionCriteria">
        <radio value="@true">Yes</radio>
        <radio value="@false">No</radio>
    </radio-set>
</form-group>
