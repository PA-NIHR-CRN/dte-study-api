@using BPOR.Domain.Enums
@using BPOR.Rms.VolunteerInformation.Utility
@model CreateCriterionModel

@{
    VsiGroupEditContext context = ViewBag.Context;
    ViewData.SetSectionName(Resources.Section1Name);
    Layout = "_VsiEditLayoutForm";
}

<h1 class="govuk-heading-l">Add @Model.Type.GetNoun() criteria</h1>

<form-group for="Criterion" label-class="govuk-heading-l">
    <body-text>For <b>@Model.GroupName</b>, enter one criterion, click "Submit", and then add more.</body-text>
    <input class="govuk-input" asp-for="Criterion" type="text"></input>
</form-group>
