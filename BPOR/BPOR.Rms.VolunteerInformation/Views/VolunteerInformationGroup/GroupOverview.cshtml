@using BPOR.Domain.Enums
@using BPOR.Rms.Abstractions.Enums
@model BPOR.Rms.VolunteerInformation.Models.VsiGroupModel

@{
    VsiGroupEditContext context = ViewBag.Context;
    ViewData.SetSectionName(Resources.Section1Name);
    Layout = "_VsiEditLayout";
}

<h1 class="govuk-heading-l">Check the details you've provided</h1>

<h2 class="govuk-heading-m">Create Volunteer Groups</h2>
<dl class="govuk-summary-list">
    <div class="govuk-summary-list__row">
        <dt class="govuk-summary-list__key">
            Enter a name for this group
        </dt>
        <dd class="govuk-summary-list__value">
            @Model.Name
        </dd>
        <dd class="govuk-summary-list__actions">
            <form method="post" asp-action="RemoveGroup" asp-all-route-data="@context.ToRouteData()">
                <button class="govuk-link" type="submit">Delete</button>
            </form>
        </dd>
    </div>
</dl>

<h2 class="govuk-heading-m">Add inclusion Criteria</h2>
<dl class="govuk-summary-list">
    <div class="govuk-summary-list__row">
        <dt class="govuk-summary-list__key">
            Inclusion criteria for @Model.Name
        </dt>
        <dd class="govuk-summary-list__value">
            <ul>
                @foreach (var criterion in Model.Criteria.Where(i => i.Type == VsiGroupCriteronType.Include))
                {
                    <li>@criterion.Description</li>
                }
            </ul>
        </dd>
        <dd class="govuk-summary-list__actions">
            <a asp-action="Criteria" asp-all-route-data="@context.ToRouteData()" asp-route-type="Include">Change</a>
        </dd>
    </div>
</dl>

<h2 class="govuk-heading-m">Add exclusion Criteria</h2>
<dl class="govuk-summary-list">
    <div class="govuk-summary-list__row">
        <dt class="govuk-summary-list__key">
            Exclusion criteria for @Model.Name
        </dt>
        <dd class="govuk-summary-list__value">
            <ul>
                @foreach (var criterion in Model.Criteria.Where(i => i.Type == VsiGroupCriteronType.Exclude))
                {
                    <li>@criterion.Description</li>
                }
            </ul>
        </dd>
        <dd class="govuk-summary-list__actions">
            <a asp-action="Criteria" asp-all-route-data="@context.ToRouteData()" asp-route-type="Exclude">Change</a>
        </dd>
    </div>
</dl>

<div class="govuk-!-margin-3">
    <a asp-action="CreateGroup" asp-controller="VolunteerInformationPage" asp-all-route-data="@context.ToRouteData()" 
       class="govuk-link" >Add another group</a>
</div>
<div>
<a asp-action="Section2_Step1" asp-controller="VolunteerInformationPage" asp-all-route-data="@context.ToRouteData()" 
   class="govuk-button" data-module="govuk-button">Continue</a>
</div>