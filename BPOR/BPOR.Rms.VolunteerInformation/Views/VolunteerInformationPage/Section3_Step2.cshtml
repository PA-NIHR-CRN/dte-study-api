
@model VsiEditModel

@{
    VsiEditContext context = ViewBag.Context;
    ViewData.SetBackLinkOverride(Url.FlowNext(context, "Section3_Step1"));
    ViewData.SetSectionName(Resources.Section3Name);
    ViewData.SetSkipLink(Url.FlowNext(context, url => url.Action("Section3_Step3", context )));
    Layout = "_VsiEditLayoutForm";
}

<form-group for="ExternalWebsiteUrl" label-class="govuk-heading-l">
    <input class="govuk-input" asp-for="ExternalWebsiteUrl" type="text">
</form-group>