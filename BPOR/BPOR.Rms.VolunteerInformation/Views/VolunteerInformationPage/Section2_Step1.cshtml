@model BPOR.Rms.VolunteerInformation.Models.VsiEditModel
@inherits BPOR.Rms.VolunteerInformation.Views.VolunteerInformationPage.ViewBase<VsiEditModel>

@{
    SetFlowBackAction("Section1_Step4");
    ViewData.SetSectionName(Resources.Section2Name);
    Layout = "_VsiEditLayoutForm";
}

<form-group for="WhatYouWillDo" label-class="govuk-heading-l">
    <textarea rows="5" class="govuk-textarea" asp-for="WhatYouWillDo" maxlength="@Constants.WhatYouWillDoMaxLength"></textarea>
    <body-text>You can add up to @Constants.WhatYouWillDoMaxLength characters</body-text>
</form-group>