@model VsiEditModel
@inherits BPOR.Rms.VolunteerInformation.Views.VolunteerInformationPage.ViewBase<VsiEditModel>

@{
    VsiEditContext context = ViewBag.Context;
    SetFlowBackAction("Section2_Step4");
    ViewData.SetSectionName(Resources.Section2Name);
    Layout = "_VsiEditLayoutForm";
}

<form-group for="StudyDuration" label-class="govuk-heading-l">
    <textarea rows="5" class="govuk-textarea" asp-for="StudyDuration" maxlength="@Constants.StudyDurationMaxLength"></textarea>
    <body-text>You can add up to @Constants.StudyDurationMaxLength characters</body-text>
</form-group>