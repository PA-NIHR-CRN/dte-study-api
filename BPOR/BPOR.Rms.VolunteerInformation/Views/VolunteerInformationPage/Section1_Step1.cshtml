@model VsiEditModel
@inherits BPOR.Rms.VolunteerInformation.Views.VolunteerInformationPage.ViewBase<VsiEditModel>

@{
    ViewData.SetSectionName(Resources.Section1Name);
    SetFlowBackAction("Start", "VolunteerInformationStart");
    Layout = "_VsiEditLayoutForm";
}

<form-group for="Description" label-class="govuk-heading-l">
    <textarea rows="5" class="govuk-textarea" asp-for="Description" maxlength="@Constants.AboutTheStudyMaxLength"></textarea>
    <body-text>You can add up to @Constants.AboutTheStudyMaxLength characters</body-text>
</form-group>