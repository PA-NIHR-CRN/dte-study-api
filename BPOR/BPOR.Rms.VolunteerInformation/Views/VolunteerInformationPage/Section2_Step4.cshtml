@model VsiEditModel
@inherits BPOR.Rms.VolunteerInformation.Views.VolunteerInformationPage.ViewBase<VsiEditModel>

@{
    SetFlowBackAction("Section2_Step3");
    ViewData.SetSectionName(Resources.Section2Name);
    Layout = "_VsiEditLayoutForm";
}

<form-group for="NumberOfVisits" label-class="govuk-heading-l">
    <textarea rows="5" class="govuk-textarea" asp-for="NumberOfVisits" maxlength="@Constants.NumberOfVisitsMaxLength"></textarea>
    <body-text>You can add up to @Constants.NumberOfVisitsMaxLength characters</body-text>
</form-group>