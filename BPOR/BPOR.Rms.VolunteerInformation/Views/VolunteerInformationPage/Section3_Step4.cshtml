@model VsiEditModel

@{
    VsiEditContext context = ViewBag.Context;
    ViewData.SetBackLinkOverride(Url.FlowNext(context, "Section3_Step3"));
    ViewData.SetSectionName(Resources.Section3Name);
    ViewData.SetSkipLink(Url.Action("Section4", context ));
    Layout = "_VsiEditLayoutForm";
}

<form-group for="InfoToRegisterByEmail" label-class="govuk-heading-l">
    <input class="govuk-input" asp-for="InfoToRegisterByEmail" type="text">
</form-group>